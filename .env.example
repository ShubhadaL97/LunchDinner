# Encryption Configuration
# Set your own encryption key (minimum 32 characters recommended)
# IMPORTANT: This key should be:
# 1. Unique and secure for each environment
# 2. Never committed to version control
# 3. Managed through secure environment variable management (AWS Secrets, HashiCorp Vault, etc.)
# 4. Rotated periodically as part of security policy
ENCRYPTION_KEY=your-secret-encryption-key-min-32-chars-long!!

# Browser Configuration
HEADLESS=true
SLOW_MO=0

# Test Timeout Settings
TEST_TIMEOUT=30000
ELEMENT_TIMEOUT=10000

# Reporting
REPORT_DIR=./reports
ALLURE_REPORT=false
